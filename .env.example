# LLM Provider Configuration
# Choose "openai" or "anthropic"
MODEL_PROVIDER=openai

# OpenAI Configuration (if MODEL_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration (if MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Gmail Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_QUERY=to:your_email@gmail.com -in:chats

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_google_sheets_id_here
GOOGLE_SHEETS_TAB=Leads

# Google OAuth Token Path
GOOGLE_TOKEN_PATH=token.json

# Spam Rules Configuration
SPAM_RULES=spam_rules.yaml

# Processing Store Configuration
PROCESSED_STORE=data/processed.jsonl

# Processing Limits
MAX_THREADS=50
POLL_INTERVAL_SECONDS=300
